# Suivan Environment Variables
# Copy this file to .env.local and fill in your values

# Sui Network
NEXT_PUBLIC_SUI_NETWORK=testnet

# Deployment mode (testnet | mainnet)
# Mainnet restricts pool cycles to 30+ days, disables faucet
NEXT_PUBLIC_NETWORK=testnet

# Google OAuth Client ID for zkLogin
# Get yours at https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Smart Contract Package IDs (testnet)
NEXT_PUBLIC_PACKAGE_ID=0x63ad9b5fb0fa7f286ac05892182e4eb5896cc9165f9bd2b7d0ba1de87b81b515
NEXT_PUBLIC_FACTORY_ID=0x4484b70fdea8a4aefcfef9c6a33e13d975b2cde0ce6a2085cb8eb18cf5e6af32
NEXT_PUBLIC_FAUCET_ID=0xb0d0ce15b6c58af48216877c9df20d0ed91409b093f214fe79b29e71c103e311
NEXT_PUBLIC_USDC_TYPE=0x63ad9b5fb0fa7f286ac05892182e4eb5896cc9165f9bd2b7d0ba1de87b81b515::test_usdc::TEST_USDC
NEXT_PUBLIC_AGENT_ADDRESS=0x501f2840d1d6fb2a98299f52f671150d38e118c33e8342861dd4ad5d58b788f1

# Agent private key (for sponsored transactions / gasless)
# Used by both sponsor route and agent executor
AGENT_SECRET_KEY=your_agent_sui_private_key
SPONSOR_SECRET_KEY=your_agent_sui_private_key
