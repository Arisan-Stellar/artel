# ARTEL Environment — Testnet
# Copy this file to .env.local and adjust values as needed.
# For Vercel deployment: set these in Vercel → Environment Variables (all optional,
# defaults point to Stellar Testnet with the latest deployed contracts).

# Stellar Network
NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

